<Application
    x:Class="TrickLor.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ===== THEME DICTIONARIES (Dark / Light) ===== -->
            <ResourceDictionary.ThemeDictionaries>

                <!-- ========== AMOLED DARK ========== -->
                <ResourceDictionary x:Key="Dark">
                    <!-- Nền chính đen tuyền -->
                    <SolidColorBrush x:Key="BrushBg"          Color="#000000"/>
                    <!-- Sidebar, card, các khối hơi sáng hơn chút để phân biệt -->
                    <SolidColorBrush x:Key="BrushSidebar"     Color="#0A0A0A"/>
                    <SolidColorBrush x:Key="BrushCard"        Color="#0F0F0F"/>
                    <SolidColorBrush x:Key="BrushCardHover"   Color="#1A1A1A"/>
                    <!-- Viền xám đậm -->
                    <SolidColorBrush x:Key="BrushBorder"      Color="#1F1F1F"/>
                    <SolidColorBrush x:Key="BrushBorderLight" Color="#2A2A2A"/>
                    <!-- Text - trắng/xám sáng -->
                    <SolidColorBrush x:Key="BrushText"        Color="#E0E0E0"/>
                    <SolidColorBrush x:Key="BrushMuted"       Color="#888888"/>
                    <!-- Nền subtle, nav hover -->
                    <SolidColorBrush x:Key="BrushSubtle"      Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="BrushNavHover"    Color="#1A1A1A"/>
                    <!-- Accent giữ nguyên xanh dương -->
                    <SolidColorBrush x:Key="BrushAccentBlue"  Color="#3B82F6"/>
                </ResourceDictionary>

                <!-- ===== LIGHT (giữ nguyên như cũ) ===== -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="BrushBg"          Color="#F8FAFC"/>
                    <SolidColorBrush x:Key="BrushSidebar"     Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="BrushCard"        Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="BrushCardHover"   Color="#F1F5F9"/>
                    <SolidColorBrush x:Key="BrushBorder"      Color="#E2E8F0"/>
                    <SolidColorBrush x:Key="BrushBorderLight" Color="#CBD5E1"/>
                    <SolidColorBrush x:Key="BrushText"        Color="#0F172A"/>
                    <SolidColorBrush x:Key="BrushMuted"       Color="#64748B"/>
                    <SolidColorBrush x:Key="BrushSubtle"      Color="#E2E8F0"/>
                    <SolidColorBrush x:Key="BrushNavHover"    Color="#EFF6FF"/>
                    <SolidColorBrush x:Key="BrushAccentBlue"  Color="#3B82F6"/>
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>

            <!-- ===== ACCENT COLORS (theme-independent) ===== -->
            <SolidColorBrush x:Key="BrushAccentGreen"  Color="#22C55E"/>
            <SolidColorBrush x:Key="BrushAccentOrange" Color="#F59E0B"/>
            <SolidColorBrush x:Key="BrushAccentPurple" Color="#8B5CF6"/>
            <SolidColorBrush x:Key="BrushAccentRed"    Color="#EF4444"/>

            <!-- ===== CARD ===== -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background"      Value="{ThemeResource BrushCard}"/>
                <Setter Property="BorderBrush"     Value="{ThemeResource BrushBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="12"/>
                <Setter Property="Padding"         Value="20"/>
            </Style>
            <Style x:Key="CardSmall" TargetType="Border">
                <Setter Property="Background"      Value="{ThemeResource BrushCard}"/>
                <Setter Property="BorderBrush"     Value="{ThemeResource BrushBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="10"/>
                <Setter Property="Padding"         Value="16"/>
            </Style>

            <!-- ===== TEXT ===== -->
            <Style x:Key="PageTitle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource BrushText}"/>
                <Setter Property="FontSize"   Value="26"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>
            <Style x:Key="PageSubtitle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource BrushMuted}"/>
                <Setter Property="FontSize"   Value="13"/>
                <Setter Property="Margin"     Value="0,5,0,0"/>
            </Style>
            <Style x:Key="SectionLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource BrushMuted}"/>
                <Setter Property="FontSize"   Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin"     Value="0,0,0,10"/>
            </Style>

            <!-- ===== PRIMARY BUTTON ===== -->
            <Style x:Key="BtnPrimary" TargetType="Button">
                <Setter Property="Background"      Value="{ThemeResource BrushAccentBlue}"/>
                <Setter Property="Foreground"      Value="White"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
                <Setter Property="Padding"         Value="20,10"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius"    Value="8"/>
            </Style>
            <Style x:Key="BtnGreen" BasedOn="{StaticResource BtnPrimary}" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BrushAccentGreen}"/>
            </Style>
            <Style x:Key="BtnOrange" BasedOn="{StaticResource BtnPrimary}" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BrushAccentOrange}"/>
            </Style>
            <Style x:Key="BtnPurple" BasedOn="{StaticResource BtnPrimary}" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BrushAccentPurple}"/>
            </Style>
            <Style x:Key="BtnRed" BasedOn="{StaticResource BtnPrimary}" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BrushAccentRed}"/>
            </Style>

            <!-- ===== GHOST BUTTON ===== -->
            <Style x:Key="BtnGhost" TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="Foreground"      Value="{ThemeResource BrushMuted}"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Padding"         Value="14,8"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush"     Value="{ThemeResource BrushBorder}"/>
                <Setter Property="CornerRadius"    Value="7"/>
            </Style>

            <!-- ===== NAV BUTTON ===== -->
            <Style x:Key="NavBtn" TargetType="Button">
                <Setter Property="Background"               Value="Transparent"/>
                <Setter Property="Foreground"               Value="{ThemeResource BrushMuted}"/>
                <Setter Property="FontSize"                 Value="13"/>
                <Setter Property="Padding"                  Value="14,11"/>
                <Setter Property="BorderThickness"          Value="0"/>
                <Setter Property="HorizontalAlignment"      Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="CornerRadius"             Value="8"/>
                <Setter Property="Margin"                   Value="8,2"/>
            </Style>

            <!-- ===== INPUT BOX ===== -->
            <Style x:Key="InputBox" TargetType="TextBox">
                <Setter Property="Background"      Value="{ThemeResource BrushBg}"/>
                <Setter Property="Foreground"      Value="{ThemeResource BrushText}"/>
                <Setter Property="BorderBrush"     Value="{ThemeResource BrushBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Padding"         Value="10,8"/>
                <Setter Property="CornerRadius"    Value="8"/>
            </Style>

            <!-- ===== SWATCH BUTTON ===== -->
            <Style x:Key="SwatchBtn" TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="0"/>
                <Setter Property="Margin"          Value="0,0,8,8"/>
                <Setter Property="CornerRadius"    Value="10"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>