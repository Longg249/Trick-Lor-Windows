<Window x:Class="WinDeployPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trick Lỏ Pro Vip
        "
        Width="1200" Height="740"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="71*"/>
            <ColumnDefinition Width="174*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border x:Name="SidebarBorder"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="20,28,20,24">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="32" Height="32" CornerRadius="8"
                                Background="#EFF6FF" Margin="0,0,10,0">
                            <TextBlock Text="⚙" FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TrickLor" Foreground="#0F172A"
                                       FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="Pro" Foreground="#3B82F6"
                                       FontSize="15" FontWeight="Bold" Margin="-1,-5,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Background="#F1F5F9" CornerRadius="4" Padding="8,4" Margin="0,8,0,0">
                        <TextBlock Foreground="#64748B" FontSize="10" FontWeight="SemiBold">
                            <Run Text="v1.0  "/>
                            <Run Text="●" Foreground="#22C55E"/>
                            <Run Text=" Đã kết nối"/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                           Fill="#E2E8F0" Margin="0"/>

                <!-- Nav Items -->
                <StackPanel Grid.Row="1" Margin="0,16,0,0">

                    <TextBlock Text="TỔNG QUAN" Foreground="#94A3B8"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="22,0,0,8"/>

                    <!-- System Info -->
                    <Button x:Name="BtnNavSysInfo"
                            Style="{StaticResource NavBtn}"
                            Click="SysInfo_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="7" Margin="0,0,12,0">
                                <TextBlock Text="💻" FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Background="#FFFDFBFB"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="System Info"
                                           Foreground="#1E293B" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="Thông tin hệ thống"
                                           Foreground="#94A3B8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Rectangle Height="1" Fill="#E2E8F0" Margin="16,12"/>

                    <TextBlock Text="TÍNH NĂNG" Foreground="#94A3B8"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="22,0,0,8"/>

                    <!-- Deploy -->
                    <Button x:Name="BtnNavDeploy"
                            Style="{StaticResource NavBtn}"
                            Click="Deploy_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="#FFF9FBFF" Margin="0,0,12,0">
                                <TextBlock Text="🚀" FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Background="#FFF9F6F6"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtDeploy" Text="Deploy"
                                           Foreground="#1E293B" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="Cài phần mềm"
                                           Foreground="#94A3B8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Optimize -->
                    <Button x:Name="BtnNavOptimize"
                            Style="{StaticResource NavBtn}"
                            Click="Optimize_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="#FFE7E4F0" Margin="0,0,12,0">
                                <TextBlock Text="⚡" FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Optimize"
                                           Foreground="#1E293B" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="Tối ưu hệ thống"
                                           Foreground="#94A3B8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Network Fix -->
                    <Button x:Name="BtnNavNetwork"
                            Style="{StaticResource NavBtn}"
                            Click="Network_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="#FFF9F6F5" Margin="0,0,12,0">
                                <TextBlock Text="🔧" FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Network Fix"
                                           Foreground="#1E293B" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="Sửa lỗi mạng"
                                           Foreground="#94A3B8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Security -->
                    <Button x:Name="BtnNavSecurity"
                            Style="{StaticResource NavBtn}"
                            Click="Security_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="#FFF5F4F8" Margin="0,0,12,0">
                                <TextBlock Text="🔒" FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Security"
                                           Foreground="#1E293B" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="Cấu hình bảo mật"
                                           Foreground="#94A3B8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Quick Setup -->
                    <Button x:Name="BtnNavQuickSetup"
                            Style="{StaticResource NavBtn}"
                            Click="QuickSetup_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="#FFF3FDFA" Margin="0,0,12,0">
                                <TextBlock Text="⚡" FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Thiết lập nhanh"
                                           Foreground="#1E293B" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="Tinh chỉnh hệ thống"
                                           Foreground="#94A3B8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Rectangle Height="1" Fill="#E2E8F0" Margin="16,16"/>

                    <TextBlock Text="CÔNG CỤ" Foreground="#94A3B8"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="22,0,0,8"/>

                    <!-- BitLocker -->
                    <Button Style="{StaticResource NavBtn}" Click="BitLocker_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="#FFF8F9F9" Margin="0,0,12,0">
                                <TextBlock Text="🔑" FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="BitLocker"
                                           Foreground="#1E293B" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="Mã hoá ổ đĩa"
                                           Foreground="#94A3B8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Logs -->
                    <Button Style="{StaticResource NavBtn}" Click="Logs_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="#F1F5F9" Margin="0,0,12,0">
                                <TextBlock Text="📋" FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Activity Log"
                                           Foreground="#1E293B" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="Lịch sử thao tác"
                                           Foreground="#94A3B8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Bottom info -->
                <Border x:Name="BottomCard"
                        Grid.Row="2" Margin="12,10,20,16" Padding="12"
                        Background="#F8FAFC" CornerRadius="8"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="💻  Máy chủ: localhost"
                                   Foreground="#64748B" FontSize="11"/>
                        <TextBlock Text="👤  Admin"
                                   Foreground="#64748B" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- ===== CONTENT FRAME ===== -->
        <Frame x:Name="MainFrame"
               x:FieldModifier="public"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="#FFFFFF" Margin="0,0,10,0" Grid.ColumnSpan="2"/>

    </Grid>
</Window>
