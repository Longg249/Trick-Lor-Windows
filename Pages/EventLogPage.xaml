<Page x:Class="TrickLor.Pages.EventLogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BrushBg}"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="📋 Event Log Viewer"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Xem nhật ký sự kiện Windows — lỗi, cảnh báo hệ thống và ứng dụng"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="32,24">
            <Border Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Nguồn log:" VerticalAlignment="Center"
                                       Foreground="{DynamicResource BrushMuted}" FontSize="12" Margin="0,0,8,0"/>
                            <ComboBox x:Name="CmbLog" Width="130" VerticalAlignment="Center" Margin="0,0,16,0"
                                      FontSize="12" SelectedIndex="0">
                                <ComboBoxItem>System</ComboBoxItem>
                                <ComboBoxItem>Application</ComboBoxItem>
                                <ComboBoxItem>Security</ComboBoxItem>
                            </ComboBox>
                            <CheckBox x:Name="ChkErrorsOnly" Content="Chỉ lỗi &amp; cảnh báo"
                                      IsChecked="True" VerticalAlignment="Center"
                                      Foreground="{DynamicResource BrushText}" FontSize="12" Margin="0,0,16,0"/>
                            <Button Content="↺  Tải" Style="{StaticResource BtnGhost}"
                                    Click="Load_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Loading -->
                    <TextBlock x:Name="TxtLoading" Grid.Row="1" Text="⏳ Đang đọc Event Log..."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource BrushMuted}" FontSize="14" Visibility="Collapsed"/>

                    <!-- DataGrid -->
                    <DataGrid x:Name="DgEvents" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0"
                              RowBackground="{DynamicResource BrushBg}"
                              AlternatingRowBackground="{DynamicResource BrushSubtle}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource BrushBorder}"
                              HeadersVisibility="Column"
                              CanUserReorderColumns="False" CanUserResizeRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              FontSize="11" Visibility="Collapsed">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Thời gian" Binding="{Binding Time}"    Width="120"/>
                            <DataGridTextColumn Header="Mức độ"   Binding="{Binding Level}"   Width="90"/>
                            <DataGridTextColumn Header="Nguồn"    Binding="{Binding Source}"  Width="150"/>
                            <DataGridTextColumn Header="Thông báo" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS -->
        <Border Grid.Row="2" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtStatus" Text="Chọn nguồn log và nhấn Tải"
                       Foreground="{DynamicResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>
