<Page x:Class="TrickLor.Pages.ProcessManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:TrickLor.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
      mc:Ignorable="d"
      Background="{ThemeResource BrushBg}"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="⚙ Process Manager"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Xem tiến trình đang chạy, RAM sử dụng — chọn và nhấn Kết thúc để kết thúc tiến trình"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="32,24">
            <Border Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="↺  Làm mới" Style="{StaticResource BtnGhost}"
                                    Click="Refresh_Click" Margin="0,0,8,0"/>
                            <Button Content="⛔  Kết thúc tiến trình" Style="{StaticResource BtnRed}"
                                    Click="Kill_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid -->
                    <controls:DataGrid x:Name="DgProcs" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                   Background="Transparent" BorderThickness="0"
                   RowBackground="{ThemeResource BrushBg}"
                   AlternatingRowBackground="{ThemeResource BrushSubtle}"
                   GridLinesVisibility="Horizontal"
                   HorizontalGridLinesBrush="{ThemeResource BrushBorder}"
                   HeadersVisibility="Column"
                   CanUserReorderColumns="False"
                   CanUserResizeColumns="False"
                   FontSize="12"
                   SelectionMode="Single">
                        <controls:DataGrid.Columns>
                            <controls:DataGridTextColumn Header="Tên tiến trình" Binding="{Binding Name}"   Width="260"/>
                            <controls:DataGridTextColumn Header="PID"            Binding="{Binding PID}"    Width="80"/>
                            <controls:DataGridTextColumn Header="RAM sử dụng"   Binding="{Binding RamStr}" Width="120"/>
                        </controls:DataGrid.Columns>
                    </controls:DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS -->
        <Border Grid.Row="2" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtStatus" Text="Đang tải danh sách tiến trình..."
                       Foreground="{ThemeResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>
