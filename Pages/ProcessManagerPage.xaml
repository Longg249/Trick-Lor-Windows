<Page x:Class="TrickLor.Pages.ProcessManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BrushBg}"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="⚙ Process Manager"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Xem tiến trình đang chạy, RAM sử dụng — chọn và nhấn Kết thúc để kết thúc tiến trình"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="32,24">
            <Border Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="↺  Làm mới" Style="{StaticResource BtnGhost}"
                                    Click="Refresh_Click" Margin="0,0,8,0"/>
                            <Button Content="⛔  Kết thúc tiến trình" Style="{StaticResource BtnRed}"
                                    Click="Kill_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid x:Name="DgProcs" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0"
                              RowBackground="{DynamicResource BrushBg}"
                              AlternatingRowBackground="{DynamicResource BrushSubtle}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource BrushBorder}"
                              HeadersVisibility="Column"
                              CanUserReorderColumns="False" CanUserResizeRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên tiến trình" Binding="{Binding Name}"   Width="260"/>
                            <DataGridTextColumn Header="PID"            Binding="{Binding PID}"    Width="80"/>
                            <DataGridTextColumn Header="RAM sử dụng"   Binding="{Binding RamStr}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS -->
        <Border Grid.Row="2" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtStatus" Text="Đang tải danh sách tiến trình..."
                       Foreground="{DynamicResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>
