<Page x:Class="TrickLor.Pages.DeployPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:TrickLor.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BrushBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitle}" Text="🚀 Software Deploy"/>
                    <TextBlock Style="{StaticResource PageSubtitle}"
                               Text="Chọn phần mềm cần cài đặt — hệ thống sẽ tự động tải và cài qua winget"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnGhost}" Content="☐  Bỏ chọn tất"
                            Click="DeselectAll_Click" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource BtnGhost}" Content="☑  Chọn tất"
                            Click="SelectAll_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- APP GRID -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24,32,8">
            <StackPanel>

                <!-- ========== TÌM KIẾM WINGET (đã dời lên đầu) ========== -->
                <TextBlock Text="TÌM KIẾM TRÊN WINGET" Style="{StaticResource SectionLabel}" Margin="0,0,0,10"/>
                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtWingetSearch" Grid.Column="0" 
                                     Style="{StaticResource InputBox}" 
                                     PlaceholderText="Nhập tên phần mềm, ví dụ: Firefox..."
                                     KeyDown="WingetSearch_KeyDown"/>
                            <Button x:Name="BtnWingetSearch" Grid.Column="1" 
                                    Style="{StaticResource BtnPrimary}" 
                                    Content="🔍 Tìm" 
                                    Click="WingetSearch_Click" 
                                    Margin="10,0,0,0" Width="100"/>
                        </Grid>

                        <!-- Kết quả tìm kiếm -->
                        <TextBlock x:Name="TxtWingetStatus" Margin="0,10,0,0" 
                                   Foreground="{ThemeResource BrushMuted}" FontSize="12"/>
                        <ItemsControl x:Name="WingetResultsList" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                           Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Id}" 
                                                           Foreground="{ThemeResource BrushMuted}" FontSize="10" FontFamily="Consolas"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Version}" 
                                                       Foreground="{ThemeResource BrushMuted}" FontSize="10"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button x:Name="BtnInstallSelected" Content="▶ Cài đặt các mục đã chọn" 
                                Style="{StaticResource BtnGreen}" 
                                Click="InstallSelectedWinget_Click"
                                IsEnabled="False" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- TIỆN ÍCH HỆ THỐNG -->
                <TextBlock Text="TIỆN ÍCH HỆ THỐNG" Style="{StaticResource SectionLabel}"/>
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0 -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="📦" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="7-Zip" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Nén / giải nén file" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="Chk7Zip" Grid.Column="1" IsChecked="True" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="📝" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Notepad++" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Trình soạn thảo văn bản" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkNotepad" Grid.Column="1" IsChecked="True" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="🖥" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="PowerToys" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Công cụ Windows nâng cao" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkPowerToys" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <!-- Row 2 -->
                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F0FDF4" Margin="0,0,12,0">
                                    <TextBlock Text="🔒" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="KeePass" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Quản lý mật khẩu" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkKeePass" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="📡" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="TreeSize Free" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Phân tích dung lượng ổ đĩa" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkTreeSize" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="🧹" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="CCleaner" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Dọn dẹp hệ thống" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkCCleaner" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <!-- Row 4 -->
                    <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="🖨" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="NAPS2" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Scan &amp; chuyển đổi PDF" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkNaps2" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4" Grid.Column="2" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF7ED" Margin="0,0,12,0">
                                    <TextBlock Text="📄" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Foxit Reader" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Đọc &amp; chú thích PDF" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkFoxitReader" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- TRÌNH DUYỆT -->
                <TextBlock Text="TRÌNH DUYỆT" Style="{StaticResource SectionLabel}"/>
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="🌐" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Google Chrome" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Trình duyệt web" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkChrome" Grid.Column="1" IsChecked="True" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF7ED" Margin="0,0,12,0">
                                    <TextBlock Text="🦊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Firefox" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Trình duyệt mã nguồn mở" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkFirefox" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF1F2" Margin="0,0,12,0">
                                    <TextBlock Text="🌊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Brave" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Bảo mật &amp; chặn quảng cáo" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkBrave" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- LẬP TRÌNH -->
                <TextBlock Text="LẬP TRÌNH" Style="{StaticResource SectionLabel}"/>
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="💻" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="VS Code" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Code editor" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkVSCode" Grid.Column="1" IsChecked="True" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="🐙" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Git" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Quản lý version" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkGit" Grid.Column="1" IsChecked="True" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F0FDF4" Margin="0,0,12,0">
                                    <TextBlock Text="🐍" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Python 3" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Ngôn ngữ lập trình" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkPython" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ĐIỀU KHIỂN TỪ XA -->
                <TextBlock Text="ĐIỀU KHIỂN TỪ XA" Style="{StaticResource SectionLabel}"/>
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF7ED" Margin="0,0,12,0">
                                    <TextBlock Text="🖥" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="AnyDesk" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Remote desktop" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkAnyDesk" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="📡" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="TeamViewer" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Hỗ trợ từ xa" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkTeamViewer" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="🔑" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="PuTTY" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="SSH client" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkPuTTY" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- BỘ OFFICE -->
                <TextBlock Text="BỘ OFFICE" Style="{StaticResource SectionLabel}"/>
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF7ED" Margin="0,0,12,0">
                                    <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="WPS Office" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Thay thế MS Office miễn phí" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkWPS" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F0FDF4" Margin="0,0,12,0">
                                    <TextBlock Text="📝" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="LibreOffice" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Bộ office mã nguồn mở" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkLibreOffice" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource CardSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="🗂" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="OnlyOffice" Foreground="{ThemeResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Tương thích .docx/.xlsx tốt" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkOnlyOffice" Grid.Column="1" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- PDF -->
                <TextBlock Text="PDF" Style="{StaticResource SectionLabel}"/>
