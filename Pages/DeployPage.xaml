<Page x:Class="WinDeployPro.Pages.DeployPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource BrushSidebar}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitle}" Text="🚀 Software Deploy"/>
                    <TextBlock Style="{StaticResource PageSubtitle}"
                               Text="Chọn phần mềm cần cài đặt — hệ thống sẽ tự động tải và cài qua winget"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnGhost}" Content="☐  Bỏ chọn tất"
                            Click="DeselectAll_Click" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource BtnGhost}" Content="☑  Chọn tất"
                            Click="SelectAll_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- APP GRID -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24,32,8">
            <StackPanel>

                <!-- TIỆN ÍCH HỆ THỐNG -->
                <TextBlock Text="TIỆN ÍCH HỆ THỐNG" Style="{StaticResource SectionLabel}"/>
                <UniformGrid Columns="3" Margin="0,0,0,28">
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="📦" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="7-Zip" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Nén / giải nén file" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="Chk7Zip" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="True" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="📝" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Notepad++" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Trình soạn thảo văn bản" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkNotepad" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="True" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="🖥" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="PowerToys" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Công cụ Windows nâng cao" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkPowerToys" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F0FDF4" Margin="0,0,12,0">
                                    <TextBlock Text="🔒" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="KeePass" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Quản lý mật khẩu" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkKeePass" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="📡" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="TreeSize Free" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Phân tích dung lượng ổ đĩa" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkTreeSize" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="🧹" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="CCleaner" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Dọn dẹp hệ thống" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkCCleaner" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="🖨" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="NAPS2" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Scan &amp; chuyển đổi PDF" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkNaps2" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF7ED" Margin="0,0,12,0">
                                    <TextBlock Text="📄" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Foxit Reader" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Đọc &amp; chú thích PDF" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkFoxitReader" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- TRÌNH DUYỆT -->
                <TextBlock Text="TRÌNH DUYỆT" Style="{StaticResource SectionLabel}"/>
                <UniformGrid Columns="3" Margin="0,0,0,28">
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="🌐" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Google Chrome" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Trình duyệt web" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkChrome" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="True" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF7ED" Margin="0,0,12,0">
                                    <TextBlock Text="🦊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Firefox" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Trình duyệt mã nguồn mở" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkFirefox" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF1F2" Margin="0,0,12,0">
                                    <TextBlock Text="🌊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Brave" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Bảo mật &amp; chặn quảng cáo" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkBrave" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- LẬP TRÌNH -->
                <TextBlock Text="LẬP TRÌNH" Style="{StaticResource SectionLabel}"/>
                <UniformGrid Columns="3" Margin="0,0,0,28">
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="💻" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="VS Code" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Code editor" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkVSCode" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="True" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="🐙" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Git" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Quản lý version" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkGit" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="True" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F0FDF4" Margin="0,0,12,0">
                                    <TextBlock Text="🐍" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Python 3" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Ngôn ngữ lập trình" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkPython" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- ĐIỀU KHIỂN TỪ XA -->
                <TextBlock Text="ĐIỀU KHIỂN TỪ XA" Style="{StaticResource SectionLabel}"/>
                <UniformGrid Columns="3" Margin="0,0,0,16">
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF7ED" Margin="0,0,12,0">
                                    <TextBlock Text="🖥" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="AnyDesk" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Remote desktop" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkAnyDesk" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="📡" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="TeamViewer" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Hỗ trợ từ xa" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkTeamViewer" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="🔑" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="PuTTY" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="SSH client" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkPuTTY" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- BỘ OFFICE -->
                <TextBlock Text="BỘ OFFICE" Style="{StaticResource SectionLabel}"/>
                <UniformGrid Columns="3" Margin="0,0,0,28">
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF7ED" Margin="0,0,12,0">
                                    <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="WPS Office" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Thay thế MS Office miễn phí" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkWPS" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F0FDF4" Margin="0,0,12,0">
                                    <TextBlock Text="📝" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="LibreOffice" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Bộ office mã nguồn mở" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkLibreOffice" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="🗂" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="OnlyOffice" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Tương thích .docx/.xlsx tốt" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkOnlyOffice" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- PDF -->
                <TextBlock Text="PDF" Style="{StaticResource SectionLabel}"/>
                <UniformGrid Columns="3" Margin="0,0,0,28">
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF1F2" Margin="0,0,12,0">
                                    <TextBlock Text="📕" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Adobe Acrobat Reader" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Đọc PDF chuẩn nhất" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkAdobeReader" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                    <TextBlock Text="📄" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Sumatra PDF" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Nhẹ &amp; nhanh" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkSumatraPDF" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F0FDF4" Margin="0,0,12,0">
                                    <TextBlock Text="🖨" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="PDF24" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Tạo / merge / chỉnh PDF" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkPDF24" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- GIAO TIẾP -->
                <TextBlock Text="GIAO TIẾP &amp; HỌP ONLINE" Style="{StaticResource SectionLabel}"/>
                <UniformGrid Columns="3" Margin="0,0,0,28">
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="📹" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Zoom" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Họp video" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkZoom" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F5F3FF" Margin="0,0,12,0">
                                    <TextBlock Text="👥" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Microsoft Teams" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Cộng tác nhóm" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkTeams" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="📞" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Skype" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Gọi video" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkSkype" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F5F3FF" Margin="0,0,12,0">
                                    <TextBlock Text="💬" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Slack" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Chat nhóm" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkSlack" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="✈" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Telegram" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Nhắn tin &amp; kênh" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkTelegram" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- EMAIL & LƯU TRỮ -->
                <TextBlock Text="EMAIL &amp; LƯU TRỮ ĐÁM MÂY" Style="{StaticResource SectionLabel}"/>
                <UniformGrid Columns="3" Margin="0,0,0,28">
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F0FDF4" Margin="0,0,12,0">
                                    <TextBlock Text="📧" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Thunderbird" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Email client mã nguồn mở" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkThunderbird" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF7ED" Margin="0,0,12,0">
                                    <TextBlock Text="☁" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Google Drive" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Đồng bộ Google Drive" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkGoogleDrive" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="📦" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Dropbox" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Lưu trữ đám mây" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkDropbox" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,0,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="🔷" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="OneDrive" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Đồng bộ Microsoft OneDrive" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkOneDrive" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- ĐA PHƯƠNG TIỆN -->
                <TextBlock Text="ĐA PHƯƠNG TIỆN &amp; KHÁC" Style="{StaticResource SectionLabel}"/>
                <UniformGrid Columns="3" Margin="0,0,0,16">
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#FFF1F2" Margin="0,0,12,0">
                                    <TextBlock Text="🎬" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="VLC Media Player" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Xem video mọi định dạng" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkVLC" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,12">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F0FDF4" Margin="0,0,12,0">
                                    <TextBlock Text="📷" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ShareX" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Chụp màn hình chuyên nghiệp" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkShareX" Grid.Column="1" Style="{StaticResource AppCheck}" IsChecked="False" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </UniformGrid>

            </StackPanel>
        </ScrollViewer>

        <!-- BOTTOM ACTION BAR -->
        <Border Grid.Row="2" Background="{StaticResource BrushSidebar}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock x:Name="TxtStatus" Text="Chọn phần mềm và nhấn Cài đặt"
                                   Foreground="{StaticResource BrushMuted}" FontSize="13"/>
                        <TextBlock x:Name="TxtCount" Text="" Foreground="#3B82F6" FontSize="13" Margin="8,0,0,0"/>
                    </StackPanel>
                    <ProgressBar x:Name="ProgressInstall" Width="320" HorizontalAlignment="Left"
                                 Value="0" Maximum="100" Height="4"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnInstall" Style="{StaticResource BtnPrimary}"
                            Content="▶  Cài đặt đã chọn" Click="InstallSelected_Click" MinWidth="160"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Page>
