<Page x:Class="TrickLor.Pages.LogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:TrickLor.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BrushBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitle}" Text="📋 Activity Log"/>
                    <TextBlock Style="{StaticResource PageSubtitle}"
                               Text="Lịch sử toàn bộ thao tác đã thực hiện trong phiên này"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource BtnRed}"
                        Content="🗑  Xoá log" Click="ClearLog_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- LOG LIST -->
        <Border Grid.Row="1" Margin="32,24" Style="{StaticResource Card}" Padding="0">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" Padding="24,20">
                <ItemsControl x:Name="LogList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Time}" Foreground="{ThemeResource BrushBorderLight}"
                                           FontFamily="Consolas" FontSize="12" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1" Text="{Binding Message}"
                                           Foreground="{ThemeResource BrushText}"
                                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- BOTTOM -->
        <Border Grid.Row="2" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtLogCount" Foreground="{ThemeResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>
