<Page x:Class="TrickLor.Pages.DriverPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BrushBg}"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="🔌 Driver Info"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Danh sách driver thiết bị — cảnh báo driver chưa ký hoặc có lỗi (WMI, có thể mất vài giây)"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="32,24">
            <Border Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="↺  Làm mới" Style="{StaticResource BtnGhost}"
                                    Click="Refresh_Click" Margin="0,0,8,0"/>
                            <TextBlock Text="Lọc:" VerticalAlignment="Center" Foreground="{DynamicResource BrushMuted}"
                                       FontSize="12" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtFilter" Style="{StaticResource InputBox}"
                                     Width="200" Height="32" VerticalAlignment="Center"
                                     TextChanged="Filter_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- Loading -->
                    <TextBlock x:Name="TxtLoading" Grid.Row="1" Text="⏳ Đang truy vấn WMI, vui lòng đợi..."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource BrushMuted}" FontSize="14" Visibility="Collapsed"/>

                    <!-- DataGrid -->
                    <DataGrid x:Name="DgDrivers" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0"
                              RowBackground="{DynamicResource BrushBg}"
                              AlternatingRowBackground="{DynamicResource BrushSubtle}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource BrushBorder}"
                              HeadersVisibility="Column"
                              CanUserReorderColumns="False" CanUserResizeRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              FontSize="12" Visibility="Collapsed">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên thiết bị"   Binding="{Binding Name}"         Width="260"/>
                            <DataGridTextColumn Header="Phiên bản"       Binding="{Binding Version}"      Width="120"/>
                            <DataGridTextColumn Header="Nhà sản xuất"   Binding="{Binding Manufacturer}" Width="180"/>
                            <DataGridTextColumn Header="Trạng thái"     Binding="{Binding Status}"       Width="90"/>
                            <DataGridTextColumn Header="Đã ký"          Binding="{Binding SignedStr}"    Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS -->
        <Border Grid.Row="2" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtStatus" Text="Đang tải..."
                       Foreground="{DynamicResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>
