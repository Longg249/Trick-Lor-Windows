<Page x:Class="TrickLor.Pages.WindowsUpdatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BrushBg}"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="🔄 Windows Update"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Tạm dừng hoặc tiếp tục cập nhật Windows thông qua Group Policy"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Status card -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="36" Height="36" CornerRadius="10" Background="#EFF6FF" Margin="0,0,12,0">
                                <TextBlock Text="🔄" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Trạng thái cập nhật" Foreground="{DynamicResource BrushText}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Windows Update via Registry" Foreground="{DynamicResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <Border x:Name="StatusCard" CornerRadius="8" Padding="16,12" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TxtStatusIcon" Text="⏳" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtUpdateStatus" Text="Đang kiểm tra..."
                                               Foreground="{DynamicResource BrushText}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtUpdateDesc" Text=""
                                               Foreground="{DynamicResource BrushMuted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Button x:Name="BtnPause" Content="⏸  Tạm dừng cập nhật" Style="{StaticResource BtnOrange}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="Pause_Click"/>
                        <Button x:Name="BtnResume" Content="▶  Tiếp tục cập nhật" Style="{StaticResource BtnGreen}"
                                HorizontalAlignment="Stretch" Click="Resume_Click"/>
                    </StackPanel>
                </Border>

                <!-- Info card -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="36" Height="36" CornerRadius="10" Background="#FFF5F3FF" Margin="0,0,12,0">
                                <TextBlock Text="ℹ" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Thao tác nhanh" Foreground="{DynamicResource BrushText}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Quick actions" Foreground="{DynamicResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Content="⚙  Mở Windows Update Settings" Style="{StaticResource BtnPrimary}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,12" Click="OpenSettings_Click"/>

                        <Rectangle Height="1" Fill="{DynamicResource BrushBorder}" Margin="0,0,0,12"/>

                        <TextBlock Text="Lưu ý:" Foreground="{DynamicResource BrushText}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Foreground="{DynamicResource BrushMuted}" FontSize="12" TextWrapping="Wrap" LineHeight="18">
                            • Tạm dừng qua Group Policy (NoAutoUpdate) — Windows Home có thể không hỗ trợ đầy đủ.&#x0a;
                            • Tiếp tục sẽ xoá khoá registry đã đặt trước đó.&#x0a;
                            • Khởi động lại máy để thay đổi có hiệu lực hoàn toàn.
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- STATUS -->
        <Border Grid.Row="2" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtStatus" Text="Sẵn sàng"
                       Foreground="{DynamicResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>
