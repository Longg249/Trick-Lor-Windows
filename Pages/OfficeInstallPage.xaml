<Page x:Class="TrickLor.Pages.OfficeInstallPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:TrickLor.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BrushBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="📦 Cài đặt Office"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Tải và cài đặt Microsoft Office tự động từ installoffice.org"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel>

                <!-- Giới thiệu -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Cài đặt Office từ installoffice.org" FontWeight="SemiBold" Foreground="{ThemeResource BrushText}" FontSize="15" Margin="0,0,0,8"/>
                        <TextBlock Foreground="{ThemeResource BrushMuted}" FontSize="12" TextWrapping="Wrap">
                            Công cụ sẽ tự động tải script cài đặt từ installoffice.org và chạy trên máy của bạn. Quá trình sẽ tải bộ cài Office từ Microsoft và cài đặt tự động.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Nút hành động -->
                <Button x:Name="BtnInstall" Content="▶ Bắt đầu cài đặt Office" 
                        Style="{StaticResource BtnPrimary}" 
                        Click="Install_Click"
                        HorizontalAlignment="Stretch" Height="48" Margin="0,0,0,20"/>

                <!-- Progress -->
                <ProgressBar x:Name="ProgressBar" Height="6" Value="0" Maximum="100" Margin="0,0,0,10"/>
                <TextBlock x:Name="TxtProgress" Foreground="{ThemeResource BrushMuted}" FontSize="12" TextWrapping="Wrap"/>
                <TextBlock x:Name="TxtStatus" Foreground="{ThemeResource BrushMuted}" FontSize="12" Margin="0,8,0,0"/>

            </StackPanel>
        </ScrollViewer>

        <!-- BOTTOM STATUS -->
        <Border Grid.Row="2" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock Text="Nguồn: installoffice.org" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
        </Border>
    </Grid>
</Page>