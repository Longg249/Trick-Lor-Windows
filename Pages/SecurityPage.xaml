<Page x:Class="WinDeployPro.Pages.SecurityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBg}"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource BrushSidebar}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="🔒 Windows Security"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Bật / tắt từng tuỳ chọn bảo mật, sau đó nhấn Áp dụng để chạy"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24,32,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- THÔNG BÁO & UAC -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#FFF1F2" Margin="0,0,12,0">
                                <TextBlock Text="🔔" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Thông báo &amp; Tài khoản" Foreground="{StaticResource BrushText}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Notifications &amp; account control" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Thông báo Windows (Toast)" Foreground="{StaticResource BrushText}" FontSize="13"/>
                                <TextBlock Text="Hiển thị thông báo hệ thống góc màn hình" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkToast" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="UAC (User Account Control)" Foreground="{StaticResource BrushText}" FontSize="13"/>
                                <TextBlock Text="Xác nhận khi ứng dụng yêu cầu quyền Admin" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkUAC" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>

                        <Button Style="{StaticResource BtnPrimary}"
                                Content="▶  Áp dụng" Click="ApplySecurity_Click"
                                HorizontalAlignment="Stretch" Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>

                <!-- SMARTSCREEN & ALERTS -->
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#F5F3FF" Margin="0,0,12,0">
                                <TextBlock Text="🛡" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Bộ lọc &amp; Cảnh báo" Foreground="{StaticResource BrushText}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="SmartScreen &amp; security alerts" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="SmartScreen Filter" Foreground="{StaticResource BrushText}" FontSize="13"/>
                                <TextBlock Text="Chặn ứng dụng/web chưa được xác minh" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkSmart" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BrushBorder}" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Security Alerts" Foreground="{StaticResource BrushText}" FontSize="13"/>
                                <TextBlock Text="Cảnh báo từ Windows Security Center" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkAlerts" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>

                        <Button Style="{StaticResource BtnPurple}"
                                Content="▶  Áp dụng" Click="ApplySecurity_Click"
                                HorizontalAlignment="Stretch" Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>

                <!-- FIREWALL -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#FEF2F2" Margin="0,0,12,0">
                                <TextBlock Text="🔥" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Tường lửa" Foreground="{StaticResource BrushText}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Windows Firewall" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Tường lửa Windows" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Kiểm soát lưu lượng mạng vào/ra máy tính" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkFirewall" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Background="#FFFBEB" CornerRadius="8" Padding="12,8" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" Foreground="#F59E0B" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Cảnh báo: Tắt tường lửa có thể gây nguy hiểm bảo mật"
                                           Foreground="#B45309" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="BtnApplySecurity" Style="{StaticResource BtnRed}"
                                Content="▶  Áp dụng cấu hình Security"
                                Click="ApplySecurity_Click"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>

        <!-- BOTTOM STATUS -->
        <Border Grid.Row="2" Background="{StaticResource BrushSidebar}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtSecStatus"
                       Text="⚠  Một số thay đổi yêu cầu quyền Administrator và khởi động lại"
                       Foreground="{StaticResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>
