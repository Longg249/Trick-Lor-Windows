<Page x:Class="WinDeployPro.Pages.BitLockerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BrushBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="0,0,0,1" Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitle}" Text="🔒 BitLocker Manager"/>
                    <TextBlock Style="{StaticResource PageSubtitle}"
                               Text="Kiểm tra và giải mã ổ đĩa bằng BitLocker"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource BtnGhost}"
                        Content="🔄  Làm mới" Click="Refresh_Click"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24,32,8">
            <StackPanel>

                <!-- DRIVE LIST -->
                <TextBlock Text="DANH SÁCH Ổ ĐĨA"
                           Style="{StaticResource SectionLabel}"/>

                <ItemsControl x:Name="DriveList" Margin="0,0,0,28">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardSmall}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <Border Width="44" Height="44" CornerRadius="10"
                                            Background="#1A1A1A" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding Icon}" FontSize="22"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Letter}"
                                                       Foreground="{DynamicResource BrushText}"
                                                       FontSize="15" FontWeight="Bold"
                                                       Margin="0,0,8,0"/>
                                            <Border CornerRadius="4" Padding="8,2"
                                                    Background="{Binding StatusBg}">
                                                <TextBlock Text="{Binding StatusLabel}"
                                                           Foreground="{Binding StatusFg}"
                                                           FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <ProgressBar Value="{Binding Percentage}"
                                                     Maximum="100"
                                                     Width="260" Height="4"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,8,0,2"
                                                     Foreground="{Binding ProgressColor}"/>
                                        <TextBlock Text="{Binding ProgressLabel}"
                                                   Foreground="{DynamicResource BrushMuted}"
                                                   FontSize="11"/>
                                    </StackPanel>

                                    <!-- Suspend / Resume -->
                                    <Button Grid.Column="2"
                                            Style="{StaticResource BtnGhost}"
                                            Content="{Binding SuspendLabel}"
                                            Tag="{Binding Letter}"
                                            Click="Suspend_Click"
                                            Margin="0,0,8,0"
                                            Visibility="{Binding SuspendVisible}"/>

                                    <!-- Backup Key -->
                                    <Button Grid.Column="3"
                                            Style="{StaticResource BtnGhost}"
                                            Content="🔑  Xuất Key"
                                            Tag="{Binding Letter}"
                                            Click="BackupKey_Click"
                                            Margin="0,0,8,0"
                                            Visibility="{Binding EncryptedVisible}"/>

                                    <!-- Decrypt -->
                                    <Button Grid.Column="4"
                                            Style="{Binding ActionStyle}"
                                            Content="{Binding ActionLabel}"
                                            Tag="{Binding Letter}"
                                            Click="Action_Click"
                                            Visibility="{Binding ActionVisible}"
                                            MinWidth="120"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- LOG -->
                <TextBlock Text="NHẬT KÝ THAO TÁC"
                           Style="{StaticResource SectionLabel}"/>
                <Border Background="{DynamicResource BrushBg}" CornerRadius="10"
                        BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                        Padding="16" Height="180">
                    <ScrollViewer x:Name="LogScroll"
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="LogBox"
                                   Foreground="{DynamicResource BrushMuted}"
                                   FontFamily="Consolas" FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="[Nhật ký sẽ hiển thị tại đây...]"/>
                    </ScrollViewer>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- BOTTOM STATUS -->
        <Border Grid.Row="2" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtStatus"
                       Text="⚠  Yêu cầu quyền Administrator và TPM chip"
                       Foreground="{DynamicResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>