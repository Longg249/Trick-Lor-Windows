<Page x:Class="TrickLor.Pages.DebloatPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:TrickLor.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BrushBg}"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER (giữ nguyên) -->
        <Border Grid.Row="0" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitle}" Text="🧹 Debloat"/>
                    <TextBlock Style="{StaticResource PageSubtitle}"
                               Text="Gỡ ứng dụng thừa khỏi Windows — tạo điểm khôi phục trước khi chạy"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnRestorePoint" Style="{StaticResource BtnPrimary}"
                            Content="🛡  Tạo điểm khôi phục" Click="CreateRestore_Click" MinWidth="180"/>
                    <Button Style="{StaticResource BtnGhost}" Content="Mở System Restore"
                            Click="OpenRestore_Click" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT mới: hiển thị bloatware đang cài -->
        <ScrollViewer Grid.Row="1" Padding="32,24" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Tìm kiếm & chọn hàng loạt -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtSearch" Style="{StaticResource InputBox}"
                                 PlaceholderText="🔍 Tìm kiếm bloatware..." 
                                 TextChanged="Search_TextChanged"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                            <Button Content="☑  Chọn tất cả" Style="{StaticResource BtnGhost}"
                                    Click="SelectAll_Click" Margin="0,0,8,0"/>
                            <Button Content="☐  Bỏ chọn" Style="{StaticResource BtnGhost}"
                                    Click="SelectNone_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Danh sách bloatware đang cài -->
                <TextBlock Text="BLOATWARE ĐANG CÀI ĐẶT" Style="{StaticResource SectionLabel}"/>
                <ItemsControl x:Name="BloatwareList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardSmall}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center" Margin="0,0,16,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{ThemeResource BrushText}"
                                                   FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding PackageName}"
                                                   Foreground="{ThemeResource BrushMuted}"
                                                   FontSize="10" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="#EFF6FF" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="Đã cài" Foreground="#3B82F6" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Nút gỡ bỏ -->
                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Gỡ các mục đã chọn" FontWeight="SemiBold"
                                       Foreground="{ThemeResource BrushText}"/>
                            <TextBlock x:Name="TxtProgress" Text="Chọn bloatware và nhấn Gỡ bỏ"
                                       Foreground="{ThemeResource BrushMuted}" FontSize="12"/>
                        </StackPanel>
                        <Button x:Name="BtnUninstall" Grid.Column="1" Style="{StaticResource BtnRed}"
                                Content="🗑  Gỡ bỏ đã chọn" Click="Uninstall_Click" MinWidth="160"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- BOTTOM STATUS -->
        <Border Grid.Row="2" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtStatus" Text="Sẵn sàng"
                       Foreground="{ThemeResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>