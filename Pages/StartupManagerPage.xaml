<Page x:Class="TrickLor.Pages.StartupManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:TrickLor.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
      mc:Ignorable="d"
      Background="{ThemeResource BrushBg}"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="🚦 Startup Manager"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Quản lý ứng dụng khởi động cùng Windows — chọn mục rồi nhấn Xoá để vô hiệu hóa"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="32,24">
            <Border Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="↺  Làm mới" Style="{StaticResource BtnGhost}"
                                    Click="Refresh_Click" Margin="0,0,8,0"/>
                            <Button Content="🗑  Xoá mục đã chọn" Style="{StaticResource BtnRed}"
                                    Click="Remove_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- List -->
                    <controls:DataGrid x:Name="LvStartup" Grid.Row="1"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0"
                              RowBackground="{ThemeResource BrushBg}"
                              AlternatingRowBackground="{ThemeResource BrushSubtle}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{ThemeResource BrushBorder}"
                              HeadersVisibility="Column"
                              CanUserReorderColumns="False"
                              SelectionMode="Single" FontSize="12">
                        <controls:DataGrid.Columns>
                            <controls:DataGridTextColumn Header="Tên ứng dụng"   Binding="{Binding Name}"    Width="200"/>
                            <controls:DataGridTextColumn Header="Nguồn"           Binding="{Binding Source}"  Width="140"/>
                            <controls:DataGridTextColumn Header="Lệnh khởi động" Binding="{Binding Command}" Width="*"/>
                        </controls:DataGrid.Columns>
                    </controls:DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS -->
        <Border Grid.Row="2" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtStatus" Text="Đang tải danh sách startup..."
                       Foreground="{ThemeResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>
