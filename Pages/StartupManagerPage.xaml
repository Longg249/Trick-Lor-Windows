<Page x:Class="TrickLor.Pages.StartupManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BrushBg}"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="🚦 Startup Manager"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Quản lý ứng dụng khởi động cùng Windows — chọn mục rồi nhấn Xoá để vô hiệu hóa"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="32,24">
            <Border Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="↺  Làm mới" Style="{StaticResource BtnGhost}"
                                    Click="Refresh_Click" Margin="0,0,8,0"/>
                            <Button Content="🗑  Xoá mục đã chọn" Style="{StaticResource BtnRed}"
                                    Click="Remove_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- List -->
                    <ListView x:Name="LvStartup" Grid.Row="1"
                              Background="Transparent" BorderThickness="0"
                              SelectionMode="Single" FontSize="12">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Tên ứng dụng" Width="200"
                                                DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Nguồn" Width="140"
                                                DisplayMemberBinding="{Binding Source}"/>
                                <GridViewColumn Header="Lệnh khởi động" Width="450"
                                                DisplayMemberBinding="{Binding Command}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS -->
        <Border Grid.Row="2" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtStatus" Text="Đang tải danh sách startup..."
                       Foreground="{DynamicResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>
