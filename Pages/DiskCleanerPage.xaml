<Page x:Class="TrickLor.Pages.DiskCleanerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:TrickLor.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BrushBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="🧽 Disk Cleaner"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Chọn loại file cần xoá, ước tính dung lượng rồi dọn dẹp"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24,32,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Card trái -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#FFF0FDF4" Margin="0,0,12,0">
                                <TextBlock Text="💾" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="File hệ thống" Foreground="{ThemeResource BrushText}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="System &amp; cache files" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Windows Update Cache" Foreground="{ThemeResource BrushText}" FontSize="13"/>
                                <TextBlock Text="SoftwareDistribution\Download (~GB)" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                            <CheckBox x:Name="TglWinUpdate" Grid.Column="1" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource BrushBorder}" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Prefetch" Foreground="{ThemeResource BrushText}" FontSize="13"/>
                                <TextBlock Text="C:\Windows\Prefetch" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                            <CheckBox x:Name="TglPrefetch" Grid.Column="1" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource BrushBorder}" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Windows Error Reports" Foreground="{ThemeResource BrushText}" FontSize="13"/>
                                <TextBlock Text="WER\ReportQueue" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                            <CheckBox x:Name="TglWER" Grid.Column="1" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Card phải -->
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#FFFEF3C7" Margin="0,0,12,0">
                                <TextBlock Text="🗂" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="File người dùng" Foreground="{ThemeResource BrushText}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="User temp &amp; cache" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Thumbnail Cache" Foreground="{ThemeResource BrushText}" FontSize="13"/>
                                <TextBlock Text="thumbcache_*.db trong Explorer" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                            <CheckBox x:Name="TglThumb" Grid.Column="1" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource BrushBorder}" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Temp Files (%TEMP%)" Foreground="{ThemeResource BrushText}" FontSize="13"/>
                                <TextBlock Text="Thư mục temp người dùng &amp; hệ thống" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                            <CheckBox x:Name="TglTemp" Grid.Column="1" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource BrushBorder}" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Recycle Bin" Foreground="{ThemeResource BrushText}" FontSize="13"/>
                                <TextBlock Text="Làm trống thùng rác" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                            <CheckBox x:Name="TglRecycle" Grid.Column="1" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action row -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Tổng ước tính: " Foreground="{ThemeResource BrushMuted}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtEstimate" Text="—" Foreground="{ThemeResource BrushText}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="📊 Ước tính" Style="{StaticResource BtnGhost}"
                                    Click="Estimate_Click" Margin="0,0,8,0"/>
                            <Button x:Name="BtnClean" Content="🧹 Dọn dẹp ngay" Style="{StaticResource BtnPrimary}"
                                    Click="Clean_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- STATUS -->
        <Border Grid.Row="2" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtStatus" Text="Chọn mục cần dọn và nhấn Ước tính hoặc Dọn dẹp ngay"
                       Foreground="{ThemeResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>
