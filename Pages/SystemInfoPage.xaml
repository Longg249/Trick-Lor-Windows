<Page x:Class="TrickLor.Pages.SystemInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BrushBg}"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitle}" Text="💻 System Info"/>
                    <TextBlock Style="{StaticResource PageSubtitle}"
                               Text="Thông tin phần cứng và tài nguyên hệ thống theo thời gian thực"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource BtnGhost}"
                        Content="🔄  Làm mới" Click="Refresh_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24,32,16">
            <StackPanel>

                <!-- THÔNG TIN MÁY -->
                <TextBlock Text="THÔNG TIN MÁY" Style="{StaticResource SectionLabel}"/>
                <UniformGrid Columns="4" Margin="0,0,0,24">

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="🖥  Tên máy" Foreground="{DynamicResource BrushMuted}" FontSize="11" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtMachineName" Text="..." Foreground="{DynamicResource BrushText}"
                                       FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="🔑  Mã máy" Foreground="{DynamicResource BrushMuted}" FontSize="11" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtMachineId" Text="..." Foreground="{DynamicResource BrushText}"
                                       FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="🕐  Múi giờ" Foreground="{DynamicResource BrushMuted}" FontSize="11" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtTimezone" Text="..." Foreground="{DynamicResource BrushText}"
                                       FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="🪟  Hệ điều hành" Foreground="{DynamicResource BrushMuted}" FontSize="11" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtOS" Text="..." Foreground="{DynamicResource BrushText}"
                                       FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- CPU + GPU -->
                <UniformGrid Columns="2" Margin="0,0,0,24">

                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,14,0">
                                <TextBlock Text="⚙" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="CPU" Foreground="{DynamicResource BrushMuted}" FontSize="11"/>
                                <TextBlock x:Name="TxtCpuName" Text="..." Foreground="{DynamicResource BrushText}"
                                           FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardSmall}" Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="8" Background="#F0FDF4" Margin="0,0,14,0">
                                <TextBlock Text="🎮" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="GPU" Foreground="{DynamicResource BrushMuted}" FontSize="11"/>
                                <TextBlock x:Name="TxtGpuName" Text="..." Foreground="{DynamicResource BrushText}"
                                           FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- TÀI NGUYÊN -->
                <TextBlock Text="TÀI NGUYÊN HỆ THỐNG" Style="{StaticResource SectionLabel}"/>
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- RAM -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10" Background="#EFF6FF" Margin="0,0,14,0">
                                    <TextBlock Text="🧠" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="RAM" Foreground="{DynamicResource BrushMuted}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtRamDetail" Text="..." Foreground="{DynamicResource BrushText}" FontSize="13"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtRamPct" Grid.Column="2" Text="0%"
                                           Foreground="#3B82F6" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar x:Name="BarRam" Height="14" Value="0" Maximum="100"
                                         Foreground="#3B82F6" Margin="0,0,0,8"/>
                            <Grid>
                                <TextBlock x:Name="TxtRamUsed" Text="Đã dùng: ..." Foreground="{DynamicResource BrushMuted}" FontSize="11"/>
                                <TextBlock x:Name="TxtRamFree" Text="Còn trống: ..." Foreground="{DynamicResource BrushMuted}" FontSize="11" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- DISK -->
                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10" Background="#F0FDF4" Margin="0,0,14,0">
                                    <TextBlock Text="💿" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Ổ cứng (C:)" Foreground="{DynamicResource BrushMuted}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtDiskDetail" Text="..." Foreground="{DynamicResource BrushText}" FontSize="13"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtDiskPct" Grid.Column="2" Text="0%"
                                           Foreground="#22C55E" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar x:Name="BarDisk" Height="14" Value="0" Maximum="100"
                                         Foreground="#22C55E" Margin="0,0,0,8"/>
                            <Grid>
                                <TextBlock x:Name="TxtDiskUsed" Text="Đã dùng: ..." Foreground="{DynamicResource BrushMuted}" FontSize="11"/>
                                <TextBlock x:Name="TxtDiskFree" Text="Còn trống: ..." Foreground="{DynamicResource BrushMuted}" FontSize="11" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- CPU LOAD -->
                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10" Background="#F5F3FF" Margin="0,0,14,0">
                                    <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="CPU Load" Foreground="{DynamicResource BrushMuted}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtCpuDetail" Text="Cập nhật mỗi 2 giây" Foreground="{DynamicResource BrushText}" FontSize="13"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtCpuPct" Grid.Column="2" Text="0%"
                                           Foreground="#8B5CF6" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar x:Name="BarCpu" Height="14" Value="0" Maximum="100"
                                         Foreground="#8B5CF6" Margin="0,0,0,8"/>
                            <TextBlock Text="● Live — tự cập nhật" Foreground="{DynamicResource BrushMuted}" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <!-- BATTERY -->
                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10" Background="#FFF7ED" Margin="0,0,14,0">
                                    <TextBlock Text="🔋" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Pin" Foreground="{DynamicResource BrushMuted}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtBatDetail" Text="..." Foreground="{DynamicResource BrushText}" FontSize="13"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtBatPct" Grid.Column="2" Text="—"
                                           Foreground="#F59E0B" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar x:Name="BarBat" Height="14" Value="0" Maximum="100"
                                         Foreground="#F59E0B" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtBatStatus" Text="..." Foreground="{DynamicResource BrushMuted}" FontSize="11"/>
                        </StackPanel>
                    </Border>

                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- BOTTOM STATUS -->
        <Border Grid.Row="2" Background="{DynamicResource BrushSidebar}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtSysStatus" Text="Đang tải thông tin hệ thống..."
                       Foreground="{DynamicResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>
