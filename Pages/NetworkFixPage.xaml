<Page x:Class="WinDeployPro.Pages.NetworkFixPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource BrushSidebar}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitle}" Text="🔧 Network Fix"/>
                    <TextBlock Style="{StaticResource PageSubtitle}"
                               Text="Chẩn đoán và sửa từng sự cố mạng riêng biệt"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnGhost}" Content="🔄  Làm mới"
                            Click="Refresh_Click" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource BtnRed}" Content="🔧  Fix tất cả"
                            Click="FixAll_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24,32,8">
            <StackPanel>

                <!-- DIAGNOSTICS -->
                <TextBlock Text="THÔNG TIN MẠNG HIỆN TẠI" Style="{StaticResource SectionLabel}"/>
                <UniformGrid Columns="4" Margin="0,0,0,28">
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="🌐  IP Address" Foreground="{StaticResource BrushMuted}" FontSize="11" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtIP" Text="Đang lấy..." Foreground="#3B82F6" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="🔀  Gateway" Foreground="{StaticResource BrushMuted}" FontSize="11" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtGW" Text="Đang lấy..." Foreground="#22C55E" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="📡  DNS Server" Foreground="{StaticResource BrushMuted}" FontSize="11" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtDNS" Text="Đang lấy..." Foreground="#8B5CF6" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardSmall}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="🌍  Internet" Foreground="{StaticResource BrushMuted}" FontSize="11" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtInternet" Text="Kiểm tra..." Foreground="#F59E0B" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- FIX ACTIONS -->
                <TextBlock Text="CÁC THAO TÁC SỬA LỖI" Style="{StaticResource SectionLabel}"/>

                <Border Style="{StaticResource CardSmall}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" CornerRadius="8" Background="#EFF6FF" Margin="0,0,16,0">
                            <TextBlock Text="🔌" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Reset Winsock" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Khởi tạo lại Windows Socket API — sửa lỗi kết nối TCP/IP" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusWinsock" Grid.Column="2" Text="●  Chờ" Foreground="{StaticResource BrushBorderLight}"
                                   FontSize="12" VerticalAlignment="Center" Margin="16,0"/>
                        <Button x:Name="BtnWinsock" Grid.Column="3" Style="{StaticResource BtnGhost}" Content="▶  Chạy" Click="FixWinsock_Click"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardSmall}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" CornerRadius="8" Background="#EFF6FF" Margin="0,0,16,0">
                            <TextBlock Text="🌐" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Reset TCP/IP Stack" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Đặt lại toàn bộ cấu hình mạng TCP/IP về mặc định" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusTCP" Grid.Column="2" Text="●  Chờ" Foreground="{StaticResource BrushBorderLight}"
                                   FontSize="12" VerticalAlignment="Center" Margin="16,0"/>
                        <Button x:Name="BtnTCP" Grid.Column="3" Style="{StaticResource BtnGhost}" Content="▶  Chạy" Click="FixTCP_Click"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardSmall}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" CornerRadius="8" Background="#F5F3FF" Margin="0,0,16,0">
                            <TextBlock Text="🗑" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Flush DNS Cache" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Xoá cache DNS — sửa lỗi không phân giải tên miền" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusDNS" Grid.Column="2" Text="●  Chờ" Foreground="{StaticResource BrushBorderLight}"
                                   FontSize="12" VerticalAlignment="Center" Margin="16,0"/>
                        <Button x:Name="BtnDNS" Grid.Column="3" Style="{StaticResource BtnGhost}" Content="▶  Chạy" Click="FixDNS_Click"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardSmall}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" CornerRadius="8" Background="#F0FDF4" Margin="0,0,16,0">
                            <TextBlock Text="🔍" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Bật Network Discovery" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Cho phép máy tính hiện trong mạng nội bộ" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusDiscovery" Grid.Column="2" Text="●  Chờ" Foreground="{StaticResource BrushBorderLight}"
                                   FontSize="12" VerticalAlignment="Center" Margin="16,0"/>
                        <Button x:Name="BtnDiscovery" Grid.Column="3" Style="{StaticResource BtnGhost}" Content="▶  Chạy" Click="FixDiscovery_Click"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardSmall}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" CornerRadius="8" Background="#F0FDF4" Margin="0,0,16,0">
                            <TextBlock Text="📂" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Bật File &amp; Printer Sharing" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Mở Firewall cho chia sẻ file và máy in" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusSharing" Grid.Column="2" Text="●  Chờ" Foreground="{StaticResource BrushBorderLight}"
                                   FontSize="12" VerticalAlignment="Center" Margin="16,0"/>
                        <Button x:Name="BtnSharing" Grid.Column="3" Style="{StaticResource BtnGhost}" Content="▶  Chạy" Click="FixSharing_Click"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardSmall}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" CornerRadius="8" Background="#FFF7ED" Margin="0,0,16,0">
                            <TextBlock Text="🗂" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Bật SMBv2/v3" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Kích hoạt giao thức chia sẻ SMB an toàn" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusSMB" Grid.Column="2" Text="●  Chờ" Foreground="{StaticResource BrushBorderLight}"
                                   FontSize="12" VerticalAlignment="Center" Margin="16,0"/>
                        <Button x:Name="BtnSMB" Grid.Column="3" Style="{StaticResource BtnGhost}" Content="▶  Chạy" Click="FixSMB_Click"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardSmall}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" CornerRadius="8" Background="#FFF7ED" Margin="0,0,16,0">
                            <TextBlock Text="🔄" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Khởi động lại dịch vụ mạng" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Restart Server + Workstation + Browser services" Foreground="{StaticResource BrushMuted}" FontSize="11"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusServices" Grid.Column="2" Text="●  Chờ" Foreground="{StaticResource BrushBorderLight}"
                                   FontSize="12" VerticalAlignment="Center" Margin="16,0"/>
                        <Button x:Name="BtnServices" Grid.Column="3" Style="{StaticResource BtnGhost}" Content="▶  Chạy" Click="FixServices_Click"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- BOTTOM STATUS -->
        <Border Grid.Row="2" Background="{StaticResource BrushSidebar}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtNetStatus"
                       Text="Nhấn từng nút để sửa riêng, hoặc 'Fix tất cả' để chạy toàn bộ"
                       Foreground="{StaticResource BrushMuted}" FontSize="13" VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Page>
