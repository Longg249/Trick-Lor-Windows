<Page x:Class="TrickLor.Pages.BackupRestorePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:TrickLor.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BrushBg}"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="💾 Backup &amp; Restore"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="Xuất / nhập cài đặt giao diện và theme của TrickLor"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- EXPORT -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="36" Height="36" CornerRadius="10" Background="#EFF6FF" Margin="0,0,12,0">
                                <TextBlock Text="📤" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Xuất cài đặt" Foreground="{ThemeResource BrushText}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Export settings.json ra file ngoài" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Vị trí file nguồn:" Foreground="{ThemeResource BrushMuted}" FontSize="11" Margin="0,0,0,4"/>
                        <Border Background="{ThemeResource BrushSubtle}" CornerRadius="6" Padding="10,8">
                            <TextBlock x:Name="TxtSettingsPath" Foreground="{ThemeResource BrushText}" FontSize="11"
                                       TextWrapping="Wrap" FontFamily="Consolas"/>
                        </Border>

                        <TextBlock x:Name="TxtSettingsExist" Margin="0,8,0,0" FontSize="12"/>

                        <Button Content="📤  Xuất cài đặt ra file..." Style="{StaticResource BtnPrimary}"
                                HorizontalAlignment="Stretch" Margin="0,20,0,0"
                                Click="Export_Click"/>
                    </StackPanel>
                </Border>

                <!-- IMPORT -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="36" Height="36" CornerRadius="10" Background="#F0FDF4" Margin="0,0,12,0">
                                <TextBlock Text="📥" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Nhập cài đặt" Foreground="{ThemeResource BrushText}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Import file settings.json đã xuất trước" Foreground="{ThemeResource BrushMuted}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Lưu ý:" Foreground="{ThemeResource BrushMuted}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Foreground="{ThemeResource BrushMuted}" FontSize="12" TextWrapping="Wrap">
                            Nhập cài đặt sẽ ghi đè cài đặt hiện tại. Khởi động lại ứng dụng để áp dụng.
                        </TextBlock>

                        <Border Background="{ThemeResource BrushSubtle}" CornerRadius="6" Padding="10,8" Margin="0,12,0,0">
                            <TextBlock x:Name="TxtImportPath" Text="Chưa chọn file"
                                       Foreground="{ThemeResource BrushMuted}" FontSize="11"
                                       FontFamily="Consolas" TextWrapping="Wrap"/>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Content="📂  Chọn file..." Style="{StaticResource BtnGhost}"
                                    Click="BrowseImport_Click" Margin="0,0,8,0" HorizontalAlignment="Left"/>
                            <Button x:Name="BtnImport" Content="📥  Nhập cài đặt" Style="{StaticResource BtnGreen}"
                                    Click="Import_Click" IsEnabled="False"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- STATUS -->
        <Border Grid.Row="2" Background="{ThemeResource BrushSidebar}"
                BorderBrush="{ThemeResource BrushBorder}" BorderThickness="0,1,0,0" Padding="32,14">
            <TextBlock x:Name="TxtStatus" Text="Sẵn sàng"
                       Foreground="{ThemeResource BrushMuted}" FontSize="13"/>
        </Border>
    </Grid>
</Page>
